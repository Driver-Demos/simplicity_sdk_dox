id: nvm3_crypto_se
label: NVM3 HAL for SE crypto
package: platform
description: >
  NVM3 crypto HAL for crypto HW on SE subsystem.
category: Services|NVM3
quality: production
metadata:
  sbom:
    license: Zlib
source:
  - path: platform/emdrv/nvm3/src/nvm3_hal_crypto_se.c
    unless: [trustzone_nonsecure]
include:
  - path: platform/emdrv/nvm3/inc
    file_list:
      - path: nvm3_hal_crypto.h
      - path: nvm3_hal_crypto_handle.h
    unless: [trustzone_nonsecure]
provides:
  - name: nvm3_crypto_se
requires:
  - name: se_manager
